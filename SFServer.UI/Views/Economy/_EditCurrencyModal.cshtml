@model SFServer.UI.Models.EditCurrencyViewModel

<div class="modal fade" id="editCurrencyModal_@Model.Id" tabindex="-1" aria-labelledby="editCurrencyModalLabel_@Model.Id" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <!-- Edit Form -->
            <form asp-action="EditCurrency" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="modal-header">
                    <h5 class="modal-title" id="editCurrencyModalLabel_@Model.Id">Edit Currency</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    <div class="form-group mb-3">
                        <label asp-for="Title"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="Icon"></label>
                        <input asp-for="Icon" class="form-control" />
                        <span asp-validation-for="Icon" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="RichText"></label>
                        <input asp-for="RichText" class="form-control" />
                        <span asp-validation-for="RichText" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="InitialAmount"></label>
                        <input asp-for="InitialAmount" type="number" class="form-control" min="0" />
                        <span asp-validation-for="InitialAmount" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="Capacity"></label>
                        <input asp-for="Capacity" type="number" class="form-control" min="0" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="RefillSeconds"></label>
                        <input asp-for="RefillSeconds" type="number" class="form-control" min="0" />
                        <span asp-validation-for="RefillSeconds" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="ColorHex"></label>
                        <input asp-for="ColorHex" class="form-control" placeholder="#RRGGBB" />
                        <span asp-validation-for="ColorHex" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save</button>
                </div>
            </form>
            <hr />
            <!-- Delete Currency Form -->
            <form asp-action="DeleteCurrency" method="post" onsubmit="return confirm('Are you sure you want to delete this currency?');">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Remove Currency</button>
            </form>
        </div>
    </div>
</div>
