@using Microsoft.AspNetCore.Mvc.TagHelpers
@model SFServer.UI.Models.EditInventoryItemViewModel
@{
    var modalId = "editInventoryModal_" + Model.Id;
}
<div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@($"{modalId}_Label")" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <!-- Edit Inventory Item Form -->
            <form asp-action="EditInventoryItem" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />
                <input type="hidden" name="CreatedAt" value="@Model.CreatedAt.ToString("o")" />
                <div class="modal-header">
                    <h5 class="modal-title" id="@($"{modalId}_Label")">Edit Inventory Item</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label>Name</label>
                        <input type="text" name="Name" value="@Model.Name" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label>Description</label>
                        <textarea name="Description" class="form-control">@Model.Description</textarea>
                    </div>
                    <div class="form-group mb-3">
                        <label>Quantity</label>
                        <input type="number" name="Quantity" value="@Model.Quantity" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label>Type</label>
                        <input type="text" name="Type" value="@Model.Type" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label>Image URL</label>
                        <input type="text" name="ImageUrl" value="@Model.ImageUrl" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
            <hr />
            <!-- Delete Inventory Item Form inside Edit Modal -->
            <form asp-action="DeleteInventoryItem" method="post" onsubmit="return confirm('Are you sure you want to delete this inventory item?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger w-100">Delete Item</button>
            </form>
        </div>
    </div>
</div>
