@model SFServer.UI.Models.Economy.CurrencyCreateViewModel

<div class="modal fade" id="addCurrencyModal" tabindex="-1" aria-labelledby="addCurrencyModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateCurrency" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="addCurrencyModalLabel">Add New Currency</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    <div class="form-group mb-3">
                        <label asp-for="NewCurrencyTitle"></label>
                        <input asp-for="NewCurrencyTitle" class="form-control" />
                        <span asp-validation-for="NewCurrencyTitle" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="NewCurrencyIcon"></label>
                        <input asp-for="NewCurrencyIcon" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="NewCurrencyRichText"></label>
                        <input asp-for="NewCurrencyRichText" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="NewCurrencyInitialAmount"></label>
                        <input asp-for="NewCurrencyInitialAmount" type="number" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="NewCurrencyCapacity"></label>
                        <input asp-for="NewCurrencyCapacity" type="number" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="NewCurrencyRefillSeconds"></label>
                        <input asp-for="NewCurrencyRefillSeconds" type="number" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="NewCurrencyColorHex"></label>
                        <input asp-for="NewCurrencyColorHex" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Currency</button>
                </div>
            </form>
        </div>
    </div>
</div>
