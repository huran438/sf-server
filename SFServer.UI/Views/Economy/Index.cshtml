@model SFServer.UI.Models.Economy.EconomyDisplayViewModel

@{
    ViewData["Title"] = "Economy";
}

<h1>Economy</h1>

<!-- Bootstrap Toasts -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
    <div class="toast align-items-center text-bg-danger border-0" id="errorToast" role="alert" aria-live="assertive"
         aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">@TempData["Error"]</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
    <div class="toast align-items-center text-bg-success border-0" id="successToast" role="alert" aria-live="assertive"
         aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">@TempData["Success"]</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs" id="economyTab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="wallet-tab" data-bs-toggle="tab" data-bs-target="#wallet" type="button"
                role="tab" aria-controls="wallet" aria-selected="false">Wallet</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory" type="button"
                role="tab" aria-controls="inventory" aria-selected="false">Inventory</button>
    </li>
</ul>

<div class="tab-content" id="economyTabContent">
    <!-- Wallet Tab -->
    <div class="tab-pane fade show active" id="wallet" role="tabpanel" aria-labelledby="wallet-tab">
        <h3 class="mt-3">Currencies</h3>

        <table class="table">
            <thead>
            <tr>
                <th>Title</th>
                <th>Icon</th>
                <th>Rich Text</th>
                <th>Initial Amount</th>
                <th>Capacity</th>
                <th>Refill Seconds</th>
                <th>Color</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var currency in Model.Currencies)
            {
                <tr>
                    <td>@currency.Title</td>
                    <td>@currency.Icon</td>
                    <td>@currency.RichText</td>
                    <td>@currency.InitialAmount</td>
                    <td>@currency.Capacity</td>
                    <td>@currency.RefillSeconds</td>
                    <td>@currency.Color</td>
                    <td>
                        <a asp-action="EditCurrency" asp-route-id="@currency.Id" class="btn btn-sm btn-warning">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <hr/>
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addCurrencyModal">
            Add Currency
        </button>
    </div>

    <!-- Inventory Tab -->
    <div class="tab-pane fade" id="inventory" role="tabpanel" aria-labelledby="inventory-tab">
        <h3 class="mt-3">Inventory Items</h3>
        <table class="table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Quantity</th>
                <th>Type</th>
                <th>Image</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.InventoryItems)
            {
                var modalId = "editInventoryModal_" + item.Id;
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Quantity</td>
                    <td>@item.Type</td>
                    <td><img src="@item.ImageUrl" alt="@item.Name" style="max-height: 40px;"/></td>
                    <td>@item.CreatedAt.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#@modalId">Edit
                        </button>
                        <button class="btn btn-sm btn-danger" data-bs-toggle="modal"
                                data-bs-target="#confirmDeleteModal" data-item-id="@item.Id">Delete
                        </button>
                    </td>
                </tr>

                <!-- Edit Inventory Modal -->
                <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@($"{modalId}_Label")"
                     aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-action="EditInventoryItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Id" value="@item.Id"/>
                                <input type="hidden" name="CreatedAt" value="@item.CreatedAt.ToString("o")"/>
                                <div class="modal-header">
                                    <h5 class="modal-title" id="@($"{modalId}_Label")">Edit Inventory Item</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="form-group mb-3">
                                        <label>Name</label>
                                        <input type="text" name="Name" value="@item.Name" class="form-control"/>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label>Description</label>
                                        <textarea name="Description" class="form-control">@item.Description</textarea>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label>Quantity</label>
                                        <input type="number" name="Quantity" value="@item.Quantity"
                                               class="form-control"/>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label>Type</label>
                                        <input type="text" name="Type" value="@item.Type" class="form-control"/>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label>Image URL</label>
                                        <input type="text" name="ImageUrl" value="@item.ImageUrl" class="form-control"/>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel
                                    </button>
                                    <button type="submit" class="btn btn-primary">Save</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
            </tbody>
        </table>

        <hr/>
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addInventoryModal">
            Add Item
        </button>
    </div>
</div>

<!-- Render modals (pass in new instances of the respective create view models) -->
@await Html.PartialAsync("_AddCurrencyModal", new SFServer.UI.Models.Economy.CurrencyCreateViewModel())
@await Html.PartialAsync("_AddInventoryItemModal", new SFServer.UI.Models.Economy.InventoryItemCreateViewModel())


<!-- Delete Confirmation Modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel"
     aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="deleteForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmDeleteModalLabel">Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete this item?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // Function to set the active tab by name (without the '#' prefix)
            function setActiveTab(tabName) {
                // Remove active and show classes from all nav links and tab panes
                document.querySelectorAll('.nav-link').forEach(function(navLink) {
                    navLink.classList.remove('active');
                });
                document.querySelectorAll('.tab-pane').forEach(function(tabPane) {
                    tabPane.classList.remove('active', 'show');
                });
                // Add active/show to the matching nav link and pane
                var targetNavLink = document.querySelector('.nav-link[data-bs-target="#' + tabName + '"]');
                var targetTabPane = document.getElementById(tabName);
                if (targetNavLink && targetTabPane) {
                    targetNavLink.classList.add('active');
                    targetTabPane.classList.add('active', 'show');
                }
            }

            // Read activeTab parameter from URL
            var urlParams = new URLSearchParams(window.location.search);
            var activeTab = urlParams.get('activeTab');

            // If no activeTab provided, default to "wallet" and update the URL without reloading.
            if (!activeTab) {
                activeTab = 'wallet';
                var newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname + '?activeTab=' + activeTab;
                window.history.replaceState({ path: newUrl }, '', newUrl);
            }

            // Set the correct tab based on the activeTab value
            setActiveTab(activeTab);

            // Attach click event listeners to update the URL when any tab is clicked
            document.querySelectorAll('.nav-link').forEach(function(navLink) {
                navLink.addEventListener('click', function (e) {
                    var target = navLink.getAttribute('data-bs-target');
                    if (target && target.startsWith('#')) {
                        var tabName = target.substring(1);
                        // Update URL query parameter using pushState (so back button works)
                        var newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname + '?activeTab=' + tabName;
                        window.history.pushState({ path: newUrl }, '', newUrl);
                        setActiveTab(tabName);
                    }
                });
            });
        });

        // Delete Confirmation Modal script (if present)
        const deleteModal = document.getElementById('confirmDeleteModal');
        if(deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const itemId = button.getAttribute('data-item-id');
                const form = document.getElementById('deleteForm');
                form.setAttribute('action', `/Economy/DeleteInventoryItem/${itemId}`);
            });
        }

        // Toast notifications
        window.addEventListener('DOMContentLoaded', () => {
            const errorToast = document.getElementById('errorToast');
            const successToast = document.getElementById('successToast');

            if ("@TempData["Error"]" !== "") {
                new bootstrap.Toast(errorToast).show();
            }

            if ("@TempData["Success"]" !== "") {
                new bootstrap.Toast(successToast).show();
            }
        });
    </script>
}



