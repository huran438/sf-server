@model SFServer.UI.Models.Economy.EconomyDisplayViewModel

@{
    ViewData["Title"] = "Economy";
    Layout = "_Layout";
}

<h1>Economy</h1>

<!-- Bootstrap Toasts -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
    <div class="toast align-items-center text-bg-danger border-0" id="errorToast" role="alert" aria-live="assertive"
         aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">@TempData["Error"]</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
    <div class="toast align-items-center text-bg-success border-0" id="successToast" role="alert" aria-live="assertive"
         aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">@TempData["Success"]</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs" id="economyTab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="wallet-tab" data-bs-toggle="tab" data-bs-target="#wallet" type="button"
                role="tab" aria-controls="wallet" aria-selected="false">Wallet
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory" type="button"
                role="tab" aria-controls="inventory" aria-selected="false">Inventory
        </button>
    </li>
</ul>

<div class="tab-content" id="economyTabContent">
    
    <!-- Currency Tab -->
    <div class="tab-pane fade show active" id="wallet" role="tabpanel" aria-labelledby="wallet-tab">
        <h3 class="mt-3">Currencies</h3>

        <table class="table">
            <thead>
            <tr>
                <th>Title</th>
                <th>Icon</th>
                <th>Rich Text</th>
                <th>Initial Amount</th>
                <th>Capacity</th>
                <th>Refill Seconds</th>
                <th>Color</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var currency in Model.Currencies)
            {
                <tr>
                    <td>@currency.Title</td>
                    <td>@currency.Icon</td>
                    <td>@currency.RichText</td>
                    <td>@currency.InitialAmount</td>
                    <td>@currency.Capacity</td>
                    <td>@currency.RefillSeconds</td>
                    <td>@currency.Color</td>
                    <td>
                        <button class="btn btn-sm btn-warning" data-bs-toggle="modal"
                                data-bs-target="#editCurrencyModal_@currency.Id">
                            Edit
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        @foreach (var currency in Model.Currencies)
        {
            @await Html.PartialAsync("_EditCurrencyModal", new SFServer.UI.Models.EditCurrencyViewModel
            {
                Id = currency.Id,
                Title = currency.Title,
                Icon = currency.Icon,
                RichText = currency.RichText,
                InitialAmount = currency.InitialAmount,
                Capacity = currency.Capacity,
                RefillSeconds = currency.RefillSeconds,
                ColorHex = currency.Color
            })
        }

        <hr/>
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addCurrencyModal">
            Add Currency
        </button>
    </div>

    <!-- Inventory Tab -->
    <div class="tab-pane fade" id="inventory" role="tabpanel" aria-labelledby="inventory-tab">
        <h3 class="mt-3">Inventory Items</h3>
        <table class="table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Quantity</th>
                <th>Type</th>
                <th>Image</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.InventoryItems)
            {
                var modalId = "editInventoryModal_" + item.Id;
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.Quantity</td>
                    <td>@item.Type</td>
                    <td><img src="@item.ImageUrl" alt="@item.Title" style="max-height: 40px;" /></td>
                    <td>@item.CreatedAt.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#@modalId">Edit</button>
                        @* Removed the delete button from here *@
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <!-- Render the Edit Inventory modals for each item -->
        @foreach (var item in Model.InventoryItems)
        {
            @await Html.PartialAsync("_EditInventoryItemModal", new SFServer.UI.Models.EditInventoryItemViewModel
            {
                Id = item.Id,
                Name = item.Title,
                Description = item.Description,
                Quantity = item.Quantity,
                Type = item.Type,
                ImageUrl = item.ImageUrl,
                CreatedAt = item.CreatedAt
            })
        }
        
        <hr />
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addInventoryModal">
            Add Item
        </button>
    </div>
</div>

  

    <!-- Render modals (pass in new instances of the respective create view models) -->
    @await Html.PartialAsync("_AddCurrencyModal", new SFServer.UI.Models.Economy.CurrencyCreateViewModel())
    @await Html.PartialAsync("_AddInventoryItemModal", new SFServer.UI.Models.Economy.InventoryItemCreateViewModel())

    @section Scripts {
        @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

        <script>
            document.addEventListener("DOMContentLoaded", function () {

                // Function to set the active tab by name (without the '#' prefix)
                function setActiveTab(tabName) {
                    // Remove active and show classes from all nav links and tab panes
                    document.querySelectorAll('.nav-link').forEach(function (navLink) {
                        navLink.classList.remove('active');
                    });
                    document.querySelectorAll('.tab-pane').forEach(function (tabPane) {
                        tabPane.classList.remove('active', 'show');
                    });
                    // Add active/show to the matching nav link and pane
                    var targetNavLink = document.querySelector('.nav-link[data-bs-target="#' + tabName + '"]');
                    var targetTabPane = document.getElementById(tabName);
                    if (targetNavLink && targetTabPane) {
                        targetNavLink.classList.add('active');
                        targetTabPane.classList.add('active', 'show');
                    }
                }

                // Read activeTab parameter from URL
                var urlParams = new URLSearchParams(window.location.search);
                var activeTab = urlParams.get('activeTab');

                // If no activeTab provided, default to "wallet" and update the URL without reloading.
                if (!activeTab) {
                    activeTab = 'wallet';
                    var newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname + '?activeTab=' + activeTab;
                    window.history.replaceState({path: newUrl}, '', newUrl);
                }

                // Set the correct tab based on the activeTab value
                setActiveTab(activeTab);

                // Attach click event listeners to update the URL when any tab is clicked
                document.querySelectorAll('.nav-link').forEach(function (navLink) {
                    navLink.addEventListener('click', function (e) {
                        var target = navLink.getAttribute('data-bs-target');
                        if (target && target.startsWith('#')) {
                            var tabName = target.substring(1);
                            // Update URL query parameter using pushState (so back button works)
                            var newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname + '?activeTab=' + tabName;
                            window.history.pushState({path: newUrl}, '', newUrl);
                            setActiveTab(tabName);
                        }
                    });
                });
            });
        </script>
    }